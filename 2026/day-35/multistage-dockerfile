# STAGE 1: The "Build" Stage (The heavy lifter)
FROM golang:1.21-alpine AS builder

WORKDIR /app

# Copy only what we need to build
COPY main.go .

# Build the static binary
# CGO_ENABLED=0 ensures the binary doesn't need external Linux libraries
RUN CGO_ENABLED=0 go build -o hello-app main.go

# STAGE 2: The "Final" Stage (The tiny runner)
FROM alpine:latest

WORKDIR /root/

# We ONLY copy the compiled binary from the 'builder' stage
COPY --from=builder /app/hello-app .

# Run the tiny binary
CMD ["./hello-app"]
